__pycache__/
*.pyc
*.pyo
.env
*.egg-info/
dist/
build/
# archive/legacy-v5/build/ holds checked-in build sources from the v5
# snapshot (PyInstaller spec, Inno Setup scripts, helper scripts).
# Don't ignore it.
!archive/legacy-v5/build/
!archive/legacy-v5/build/**

# ── Electron + Vite scaffold ─────────────────────────────────────────────────
node_modules/
out/
.DS_Store
*.tsbuildinfo

# ── Python sidecar build artifacts ───────────────────────────────────────────
backend/.venv/
backend/build/
backend/dist/
backend/*.spec.bak

# Bundled sidecar copy generated by 3-build-installer.bat right before electron-builder runs.
branding/sidecar-bundle/

# Local logs
*.log


# Auto-generated by backend/services/docker_manager.py.
#
# Do not edit by hand — this file is rewritten every time Power Mode starts.
# Settings (model provider, API key, workspace folder, memory limits) are
# rendered from the user's Settings panel via Jinja2.
#
# All ports are bound to 127.0.0.1 only — OpenClaw is never exposed off-box.

version: "3.8"

services:
  openclaw:
    image: {{ image }}
    container_name: {{ container_name }}
    restart: unless-stopped

    # Bind to localhost only. The host port is configurable so multiple
    # iMakeAiTeams installs can coexist on the same machine.
    ports:
      - "127.0.0.1:{{ gateway_port }}:8080"

    environment:
      OPENCLAW_BIND: "0.0.0.0:8080"
      OPENCLAW_PROVIDER: "{{ provider }}"
      OPENCLAW_MODEL: "{{ model }}"
      OPENCLAW_API_KEY: "${OPENCLAW_API_KEY:?OPENCLAW_API_KEY missing — re-render compose}"
      OPENCLAW_WORKSPACE: "/workspace"
      OPENCLAW_DATA_DIR: "/data"
      OPENCLAW_REQUIRE_APPROVAL: "true"
      OPENCLAW_LOG_LEVEL: "info"
{% if extra_env %}{% for key, value in extra_env.items() %}      {{ key }}: "{{ value }}"
{% endfor %}{% endif %}
    volumes:
      # Persistent storage for OpenClaw's task history, embeddings, caches.
      - "{{ data_dir }}:/data"
      # User-chosen workspace — the only host folder OpenClaw can touch.
      - "{{ workspace_dir }}:/workspace"

    # Bridge mode (default) keeps the container off the host network entirely.
    # The published port above is the only inbound path.
    networks:
      - openclaw_net

    deploy:
      resources:
        limits:
          memory: {{ memory_limit_mb }}M

    healthcheck:
      test: ["CMD", "wget", "-q", "--spider", "http://127.0.0.1:8080/health"]
      interval: 10s
      timeout: 3s
      retries: 6
      start_period: 20s

networks:
  openclaw_net:
    driver: bridge

# Auto-generated by backend/services/docker_manager.py.
#
# Do not edit by hand — this file is rewritten every time Power Mode starts.
# The shared secret is read from the GATEWAY_SECRET env var (see .env).
#
# This Caddy instance is the ONLY service published off the openclaw_net
# bridge. The OpenClaw container has no host-side ports of its own; reaching
# it requires going through this proxy and presenting a matching bearer token.

{
    # No host networking, no ACME, no admin API — this Caddy is purely a
    # localhost reverse proxy with header-based auth.
    auto_https off
    admin off
    persist_config off
}

:8080 {
    # Match requests carrying the exact "Authorization: Bearer <secret>"
    # header. The secret is substituted at parse time from the env file the
    # docker_manager wrote alongside this Caddyfile.
    @authed header Authorization "Bearer {$GATEWAY_SECRET}"

    handle @authed {
        reverse_proxy openclaw:8080 {
            # SSE/NDJSON: never buffer responses, stream chunks straight back
            # to the host so execution_bridge sees events as they happen.
            flush_interval -1
            transport http {
                read_timeout 0
                write_timeout 0
            }
        }
    }

    handle {
        respond "unauthorized" 401 {
            close
        }
    }
}
